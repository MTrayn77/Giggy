<!-- C21361681 – Michael Traynor
     Reusable back bar -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:padding="@dimen/space_4" android:gravity="center_vertical">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btnBack"
        android:layout_width="24dp" android:layout_height="24dp"
        app:srcCompat="@drawable/back_arrow" android:contentDescription="@string/back" />
    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/back" android:textColor="@color/giggy_green"
        android:layout_marginStart="@dimen/space_2"/>
</LinearLayout>
