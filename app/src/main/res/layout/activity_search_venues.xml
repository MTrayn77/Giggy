<?xml version="1.0" encoding="utf-8"?>
<!-- C21361681 – Michael Traynor -->
<!-- Artist: browse and search venue profiles -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/giggy_black"
    android:padding="16dp">

    <Button android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="@color/giggy_hint"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find Venues"
        android:textColor="@color/giggy_text"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Venue type filter -->
    <TextView
        style="@style/GiggyFieldLabel"
        android:text="Venue Type"/>
    <Spinner android:id="@+id/spVenueTypeFilter"
        style="@style/GiggySpinner"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"/>

    <!-- Location filter -->
    <TextView
        style="@style/GiggyFieldLabel"
        android:text="Location"/>
    <EditText android:id="@+id/etLocationFilter"
        style="@style/GiggyEditText"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="e.g. Dublin"
        android:inputType="textPostalAddress"
        android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnSearch"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Search"
        android:textColor="@color/giggy_black"
        android:background="@drawable/green_button"
        android:layout_marginBottom="16dp"/>

    <ListView android:id="@+id/listVenues"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#333333"
        android:dividerHeight="1dp"/>

</LinearLayout>