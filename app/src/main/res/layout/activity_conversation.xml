<?xml version="1.0" encoding="utf-8"?>
<!-- C21361681 – Michael Traynor -->
<!-- Conversation / messaging screen for a booking -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/giggy_black">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/giggy_dark">

        <Button android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/giggy_hint"/>

        <TextView android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Conversation"
            android:textColor="@color/giggy_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <!-- Message list -->
    <ListView android:id="@+id/listMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:divider="#222222"
        android:dividerHeight="4dp"
        android:transcriptMode="alwaysScroll"
        android:stackFromBottom="true"/>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/giggy_dark">

        <EditText android:id="@+id/etMessage"
            style="@style/GiggyEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Send"
            android:textColor="@color/giggy_black"
            android:background="@drawable/green_button"/>
    </LinearLayout>

</LinearLayout>