<!-- C21361681 – Michael Traynor
     "G [mic] ggy" logo -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:gravity="center_vertical">
    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="G" android:textSize="36sp" android:textStyle="bold"
        android:textColor="@color/giggy_green"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="28dp" android:layout_height="28dp"
        android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
        app:srcCompat="@drawable/mic" android:contentDescription="mic"
        app:tint="@color/giggy_green"/>
    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ggy" android:textSize="36sp" android:textStyle="bold"
        android:textColor="@color/giggy_green"/>
</LinearLayout>
